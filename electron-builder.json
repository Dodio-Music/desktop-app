{
    "appId": "com.underswing.dodio",
    "productName": "Dodio",

    "directories": {
        "output": "dist",
        "buildResources": "resources"
    },

    "files": [
        "out/**/*",
        "package.json",
        "resources/**/*",
        "!**/.vscode/*",
        "!src/*",
        "!electron.vite.config.*",
        "!{.env,.env.*,.npmrc}"
    ],

    "asar": true,

    "asarUnpack": [
        "resources/**",
        "**/node_modules/sharp/**/*",
        "**/node_modules/@img/**/*"
    ],

    "artifactName": "${name}-${version}-${os}-${arch}.${ext}",

    "win": {
        "icon": "resources/dodo_whiteondark.ico",
        "target": ["nsis"]
    },

    "nsis": {
        "shortcutName": "Dodio",
        "uninstallDisplayName": "Dodio",
        "createDesktopShortcut": "always"
    },

    "linux": {
        "target": ["AppImage"],
        "icon": "resources/dodo_whiteondark_512.png",
        "category": "AudioVideo"
    },

    "publish": [
        {
            "provider": "github",
            "owner": "Dodio-Music",
            "repo": "desktop-app",
            "releaseType": "release"
        }
    ],

    "npmRebuild": true,

    "protocols": [
        {
            "name": "Dodio",
            "schemes": ["dodio"]
        }
    ]
}
