{
    "name": "dodio",
    "version": "0.3.2",
    "description": "A music app for casual music enjoyers and enthusiasts.",
    "main": "./out/main/index.js",
    "author": "Dodio Team",
    "type": "module",
    "scripts": {
        "lint": "eslint --cache .",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "npm run typecheck:node && npm run typecheck:web",
        "start:local": "electron-vite preview --mode devlocal",
        "start:remote": "electron-vite preview --mode prod",
        "dev:local": "electron-vite dev --mode devlocal",
        "dev:remote": "electron-vite dev --mode devremote",
        "postinstall": "electron-builder install-app-deps",
        "build": "npm run typecheck && electron-vite build --mode prod && electron-builder",
        "build:unpack": "npm run build -- --dir",
        "build:win": "npm run build -- --win",
        "build:linux": "npm run build -- --linux",
        "test:unit": "vitest run --coverage",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/utils": "^4.0.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.6",
        "@mui/material": "^7.3.6",
        "@phosphor-icons/react": "^2.1.10",
        "@reduxjs/toolkit": "^2.9.0",
        "@stomp/stompjs": "^7.3.0",
        "@uidotdev/usehooks": "^2.4.1",
        "@underswing/naudiodon": "https://github.com/underswing/naudiodon.git#v1.0.1",
        "axios": "^1.13.5",
        "chokidar": "^5.0.0",
        "classnames": "^2.5.1",
        "dotenv": "^17.2.3",
        "electron-updater": "^6.8.3",
        "ffmpeg-static": "^5.3.0",
        "form-data": "^4.0.5",
        "got": "^14.6.5",
        "mime": "^4.1.0",
        "music-metadata": "^11.10.1",
        "node-vibrant": "^4.0.4",
        "p-limit": "^7.1.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hot-toast": "^2.6.0",
        "react-icons": "^5.5.0",
        "react-redux": "^9.2.0",
        "react-resizable-panels": "^4.6.5",
        "react-router-dom": "^7.13.0",
        "react-spinners": "^0.17.0",
        "react-switch": "^7.1.0",
        "react-virtualized": "^9.22.6",
        "sharp": "^0.34.5",
        "timeago.js": "^4.0.2"
    },
    "devDependencies": {
        "@electron-toolkit/eslint-config-ts": "^3.1.0",
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@playwright/test": "^1.56.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@types/node": "^22.16.5",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@types/react-router-dom": "^5.3.3",
        "@types/react-virtualized": "^9.22.3",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^4.0.7",
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "electron-devtools-installer": "^4.0.0",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.0",
        "jsdom": "^27.4.0",
        "playwright": "^1.56.1",
        "typescript": "^5.8.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.7"
    }
}
